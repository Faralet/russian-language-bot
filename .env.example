# Telegram
BOT_TOKEN=1234567890:PUT_YOUR_BOT_TOKEN_HERE
# Telegram ID администраторов через запятую (полный доступ к /admin).
ADMIN_TELEGRAM_IDS=123456789,987654321

# Database
DATABASE_URL=postgresql+asyncpg://russian_bot:russian_bot_password@db:5432/russian_bot

# App
APP_TIMEZONE=Europe/Moscow
FREE_DAILY_QUESTION_LIMIT=5
LESSON_QUESTIONS_COUNT=5
# Урок в стиле Duolingo: число этапов по LESSON_QUESTIONS_COUNT вопросов.
LESSON_STAGES=3
# Дневная цель (число вопросов за день) для прогресс-бара и мотивации.
DAILY_GOAL_QUESTIONS=10
RUN_DB_INIT_ON_STARTUP=true

# Premium / Telegram Stars
ENABLE_PAYMENTS=false
PREMIUM_MONTH_STARS=299
PREMIUM_MONTH_DAYS=30

# Retention
WELCOME_BONUS_DAYS=3
ENABLE_ADMIN_REPORT=true
ADMIN_REPORT_TIME=09:00

# AI: генерация черновиков и AI-проверка сочинения (К1-К10).
# По умолчанию выключено. Чтобы включить: ENABLE_AI=true + ключ + модель.
ENABLE_AI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Необязательно: базовый URL для OpenAI-совместимого API (прокси/иной провайдер).
OPENAI_BASE_URL=

# Mini App (веб-приложение в Telegram). Заполнять, когда есть домен с HTTPS.
# MINIAPP_URL — кнопка "Открыть приложение" в боте (пусто = кнопки нет).
# MINIAPP_DOMAIN — домен для Caddy (авто-HTTPS), без https://.
MINIAPP_URL=
MINIAPP_DOMAIN=
